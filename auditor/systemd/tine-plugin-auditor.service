[Unit]
Description=Tine community plugin auditor
After=network-online.target

[Service]
Type=oneshot
Environment=CODEX_BIN=/home/koutecky/bin/codex
ExecStart=/usr/bin/python3 /aux/koutecky/logseq/tine-plugin-registry/auditor/daemon.py --once --config /aux/koutecky/logseq/tine-plugin-registry/auditor/config.local.toml
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=default.target
