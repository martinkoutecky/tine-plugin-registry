[Unit]
Description=Publish completed Tine plugin audits with the narrow GitHub App

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /aux/koutecky/logseq/tine-plugin-registry/auditor/publisher_daemon.py --once --config /aux/koutecky/logseq/tine-plugin-registry/auditor/publisher-config.local.toml
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=default.target
