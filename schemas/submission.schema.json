{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tine registry submission",
  "oneOf": [
    {
      "title": "Legacy plugin submission v1",
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "pluginId", "version", "repository", "commit", "manifestPath"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "pluginId": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/version" },
        "repository": { "$ref": "#/$defs/repository" },
        "commit": { "$ref": "#/$defs/commit" },
        "manifestPath": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+manifest\\.json$" }
      }
    },
    {
      "title": "Plugin or theme submission v2",
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "kind", "packageId", "version", "repository", "commit", "manifestPath"],
      "properties": {
        "schemaVersion": { "const": 2 },
        "kind": { "enum": ["plugin", "theme"] },
        "packageId": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/version" },
        "repository": { "$ref": "#/$defs/repository" },
        "commit": { "$ref": "#/$defs/commit" },
        "manifestPath": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+(?:manifest|theme)\\.json$" }
      }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]{1,62}[a-z0-9])$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$" },
    "repository": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+(?:\\.git)?$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
  }
}
